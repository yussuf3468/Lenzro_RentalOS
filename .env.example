# =============================================================================
# Lenzro RentalOS — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# =============================================================================

# --- Supabase (client) ---------------------------------------------------------
# Project URL and the PUBLIC anon key. Safe to expose — access is gated by RLS.
# Find these in: Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- App ----------------------------------------------------------------------
# Public base URL of the deployed app (used for auth redirects, emails).
VITE_APP_URL=http://localhost:5173

# =============================================================================
# SERVER-ONLY secrets (Edge Functions / CI) — NEVER prefix with VITE_,
# NEVER expose to the client. Set these in Supabase / Vercel project secrets.
#   SUPABASE_SERVICE_ROLE_KEY=   # bypasses RLS — Edge Functions only
#   SUPABASE_DB_URL=
#   RESEND_API_KEY=              # transactional email (Phase 2+)
# =============================================================================
